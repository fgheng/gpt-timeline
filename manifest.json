{
  "manifest_version": 3,
  "name": "GPT Timeline",
  "version": "1.0.0",
  "description": "在 ChatGPT 页面右侧显示问题时间线，快速跳转到对应问题",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
